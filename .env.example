# ============================================================================
# Necessario AGORA (fase 1 - ingestao no Qdrant)
# ============================================================================
# Dentro do Docker Compose use "qdrant"; rodando fora do compose, "localhost"
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=mec_faq

APP_ENV=development

# ============================================================================
# Usado em fases futuras (chat com LLM) -- pode deixar em branco por ora
# ============================================================================
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# ============================================================================
# Usado em fases futuras (Postgres: metricas/feedback + dashboard)
# Descomente quando o servico "postgres" do docker-compose.yml for reativado
# ============================================================================
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_USER=raguser
# POSTGRES_PASSWORD=ragpassword
# POSTGRES_DB=ragdb
